# macOS
.DS_Store
*.DS_Store

# 敏感内容 / 仅本地可见（申报材料、私人笔记、旧备份、草稿等）
# 这些文件在本地工作区存在，但不会被 git 追踪
private/

# 默认忽略申报材料和压缩包（即使在 private/ 外也不追踪）
*.docx
*.xlsx
*.zip
*.tar.gz

# 爬虫相关全部不入库（数据源、抓取逻辑、部署配置都是商业资产）
backend/
crawler-worker/
crawler/
spider/
scrapy.cfg

# 工具脚本默认不入库，但 deploy.sh 例外（公开部署流程方便他人 fork 复用）
scripts/*
!scripts/deploy.sh

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Cloudflare
.wrangler/

# Logs
*.log
